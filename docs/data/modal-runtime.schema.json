          "tagName": "div",
          "text": {
            "bind": "panel.title"
          }
        },
        {
          "kind": "text",
          "className": "level-intro-panel-text",
          "tagName": "div",
          "text": {
            "bind": "panel.body"
          }
        }
      ]
    },
