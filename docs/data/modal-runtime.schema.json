{
  "kind": "atomic-smash.scene-ui-config",
  "version": 1,
  "definitions": {
    "levelIntro": {
      "kind": "container",
      "children": [
        {
          "kind": "text",
          "className": "level-intro-kicker",
          "tagName": "div",
          "text": {
            "bind": "intro.kicker"
          }
        },
        {
          "kind": "text",
          "className": "level-intro-title",
          "id": "level-intro-title",
          "tagName": "div",
          "text": {
            "bind": "intro.title"
          }
        },
        {
          "kind": "text",
          "className": "level-intro-summary",
          "tagName": "div",
          "text": {
            "bind": "intro.summary"
          }
        },
        {
          "kind": "container",
          "className": "level-intro-panels",
          "data": {
            "levelIntroPanelsSlot": "true"
          }
        },
        {
          "kind": "container",
          "className": "level-intro-actions",
          "children": [
            {
              "kind": "button",
              "className": "level-intro-action",
              "attrs": {
                "disabled": {
                  "bind": "intro.disabled"
                }
              },
              "on": {
                "click": {
                  "bind": "handlers.start"
                }
              },
              "text": {
                "bind": "intro.actionLabel"
              }
            }
          ]
        }
      ]
    },
    "levelIntroPanel": {
      "kind": "container",
